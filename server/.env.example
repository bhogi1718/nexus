PORT=5000
JWT_SECRET=your_super_secret_key_change_this
NODE_ENV=development

# AWS Region
AWS_REGION=us-east-1

# AWS Credentials (optional - use EC2 instance role in production)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# AWS DynamoDB Tables
DYNAMODB_USERS_TABLE=nexus-users
DYNAMODB_MESSAGES_TABLE=nexus-messages
DYNAMODB_CONVERSATIONS_TABLE=nexus-conversations
DYNAMODB_OTPS_TABLE=nexus-otps

# AWS S3 Configuration
AWS_S3_BUCKET=nexus-messenger

# AWS SES Configuration (OTP emails)
AWS_SES_EMAIL=your_verified_sender@example.com

CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Nexus Messenger - Production Environment Configuration
# Copy this to .env and fill in your actual values

# Server Configuration
PORT=5000
NODE_ENV=production

# Database (MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/nexus?retryWrites=true&w=majority&appName=Cluster0

# JWT Authentication
# Generate a strong random key: openssl rand -base64 32
JWT_SECRET=your-very-long-random-secret-key-here-change-this

# AWS S3 Configuration (File Uploads)
# Note: Use EC2 IAM role instead of hardcoding keys
AWS_REGION=us-east-1
AWS_S3_BUCKET=nexus-files-charan

# AWS SES Configuration (Email OTP)
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY not needed if using EC2 IAM role
AWS_SES_EMAIL=your-verified-ses-email@example.com

# Frontend Configuration
CLIENT_URL=https://yourdomain.com
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Optional: Additional security
# Rate limiting can be adjusted here if needed
